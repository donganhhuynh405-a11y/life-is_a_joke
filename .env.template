# =============================================================================
# Trading Bot — Environment Configuration Template (systemd / bare-metal)
# =============================================================================
# SETUP INSTRUCTIONS:
#   sudo cp /opt/trading-bot/.env.template /opt/trading-bot/.env
#   sudo nano /opt/trading-bot/.env        # Fill in YOUR values
#   sudo chmod 600 /opt/trading-bot/.env   # Restrict access
#
# The systemd service reads this file automatically via EnvironmentFile=
# (no python-dotenv required).
#
# NEVER commit your filled-in .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=trading-bot
# production | paper | development
APP_ENV=production
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Set to 'true' only when you have live API keys
TRADING_ENABLED=false

# -----------------------------------------------------------------------------
# Exchange API credentials  (Binance example)
# Get keys at: https://www.binance.com/en/my/settings/api-management
# For safety, always start with BINANCE_TESTNET=true to use the test network.
# -----------------------------------------------------------------------------
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET_HERE
# true = testnet (safe to test), false = live trading with real money
BINANCE_TESTNET=true

# If you use a different exchange supported via CCXT:
# EXCHANGE_ID=binance
# EXCHANGE_API_KEY=your_key
# EXCHANGE_API_SECRET=your_secret
# EXCHANGE_TESTNET=true

# -----------------------------------------------------------------------------
# Trading parameters
# These defaults are conservative. Adjust after you understand the strategy.
# -----------------------------------------------------------------------------
TRADING_SYMBOLS=BTCUSDT,ETHUSDT
DEFAULT_SYMBOL=BTCUSDT
# live | paper
TRADING_MODE=live
# enhanced | simple | classic_macd_rsi
ACTIVE_STRATEGY=enhanced

# Max fraction of balance per position (0.1 = 10%)
MAX_POSITION_SIZE=0.1
# % of balance to risk per trade
POSITION_SIZE_PERCENTAGE=2.0
# % below entry to place stop-loss
STOP_LOSS_PERCENTAGE=2.0
# % above entry to take profit
TAKE_PROFIT_PERCENTAGE=5.0
# Hard cap on trades per day
MAX_DAILY_TRADES=10
# Max simultaneous open positions
MAX_OPEN_POSITIONS=3
# Stop trading if daily loss exceeds this %
MAX_DAILY_LOSS_PERCENTAGE=5.0

# -----------------------------------------------------------------------------
# Database
# For a simple standalone deployment, SQLite is fine (no extra setup needed).
# Switch to PostgreSQL if you need concurrent access or run inside Docker.
# -----------------------------------------------------------------------------
# sqlite | postgresql
DB_TYPE=sqlite
# SQLite file path (ignored for postgresql); created automatically by venv_prestart.sh
DB_PATH=/var/lib/trading-bot/trading_bot.db

# PostgreSQL (only needed when DB_TYPE=postgresql):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=trading_bot
# DB_USER=trading_bot_user
# DB_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE
# DATABASE_URL=postgresql://trading_bot_user:YOUR_STRONG_DB_PASSWORD_HERE@localhost:5432/trading_bot

# -----------------------------------------------------------------------------
# Telegram notifications (optional)
# Create a bot via @BotFather, then get your chat ID via @userinfobot
# Steps:
#   1. Message @BotFather → /newbot → copy the token below
#   2. Message your bot once, then visit:
#      https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      and copy the chat.id value
#   3. Uncomment ENABLE_NOTIFICATIONS=true  ← notifications are OFF by default
# -----------------------------------------------------------------------------
# ENABLE_NOTIFICATIONS=true
# TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ
# TELEGRAM_CHAT_ID=987654321
# NOTIFICATION_LANGUAGE=ru

# -----------------------------------------------------------------------------
# Web dashboard / health-check endpoint (optional)
# -----------------------------------------------------------------------------
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8001

# -----------------------------------------------------------------------------
# Docker Compose extras (only needed when running with docker-compose)
# -----------------------------------------------------------------------------
# These are REQUIRED if you use docker-compose.  Choose any strong passwords
# you like — they are used only within the private Docker network.
# Generate a random password: python3 -c "import secrets; print(secrets.token_urlsafe(20))"
#
# DB_PASSWORD is the PostgreSQL password for the 'trader' database user.
# GRAFANA_PASSWORD is the admin password for the Grafana dashboard (port 3000).
#
# IMPORTANT: uncomment these lines and replace the placeholder values before
# running docker-compose.  Leaving them commented out will cause PostgreSQL and
# Grafana to receive empty passwords and may prevent them from starting.
#
# After setting these, start services with:
#   docker-compose up -d
# Access Grafana at http://YOUR_SERVER_IP:3000  (login: admin / GRAFANA_PASSWORD)
#
# DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
# GRAFANA_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
